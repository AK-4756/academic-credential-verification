# ============================================================================
# Backend .gitignore — Python/FastAPI specific
# ============================================================================

# --- Virtual Environment ---
.venv/
venv/
env/

# --- Python Cache ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Environment Variables (secrets) ---
.env.development
.env.production
.env

# --- JWT Keys ---
*.pem

# --- File Uploads (runtime generated) ---
uploads/certificates/
uploads/qr/

# --- Test Coverage ---
.coverage
htmlcov/
.pytest_cache/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Distribution ---
dist/
build/
*.egg-info/
*.egg

# --- OS ---
.DS_Store
Thumbs.db
