# ============================================================================
# Academic Credential Verification Platform — Environment Variables
# ============================================================================
# Source of truth: docs/repository-structure.md Section 7.1
# Copy this file to .env.development for local development:
#   cp .env.example .env.development
# NEVER commit .env.development or .env.production to version control.
# ============================================================================

# --- Database ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/credential_db

# --- JWT Authentication (RS256) ---
# Generate key pair with:
#   openssl genrsa -out private_key.pem 2048
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
# Then paste contents here with newlines replaced by \n
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Blockchain ---
# Local Hardhat: http://127.0.0.1:8545
# Sepolia: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# Set after contract deployment (Sprint 2)
CONTRACT_ADDRESS=
# 31337 = Hardhat local, 11155111 = Sepolia
NETWORK_CHAIN_ID=31337
NETWORK_NAME=hardhat

# --- File Upload ---
# Absolute path to the uploads directory
UPLOAD_ROOT=./uploads
# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE_BYTES=10485760

# --- Frontend CORS ---
# Vite dev server URL (default port 5173)
FRONTEND_URL=http://localhost:5173

# --- Application ---
# Show /docs and /redoc endpoints (disable in production)
SHOW_DOCS=True
# Enable debug mode (disable in production)
DEBUG=True
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
