# ============================================================================
# Academic Credential Verification Platform — Frontend Environment Variables
# ============================================================================
# Source of truth: docs/implementation-roadmap.md L409-416
# Copy this file to .env.development for local development:
#   cp .env.example .env.development
# NEVER commit .env.development or .env.production to version control.
# All variables must be prefixed with VITE_ to be accessible in the app.
# Access via: import.meta.env.VITE_VARIABLE_NAME
# ============================================================================

# --- Backend API ---
# FastAPI backend URL (dev: http://localhost:8000)
VITE_API_URL=http://localhost:8000

# --- Blockchain ---
# Smart contract address (set after contract deployment in Sprint 2)
VITE_CONTRACT_ADDRESS=
